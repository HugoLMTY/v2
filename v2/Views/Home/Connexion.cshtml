@using (Html.BeginForm(FormMethod.Post))
{
    <table>
        <tr>
            <td></td>
            <td>Conn</td>
        </tr>

        <tr>
            <td> @Html.LabelFor(model => model.Mail_User) </td>
            <td>  @Html.EditorFor(model => model.Mail_User) </td>
        </tr>
        <tr>
            <td></td>
            <td> @Html.ValidationMessageFor(model => model.Mail_User) </td>
        </tr>


        <tr>
            <td> @Html.LabelFor(model => model.Pword_User) </td>
            <td> @Html.EditorFor(model => model.Pword_User) </td>
        </tr>
        <tr>
            <td></td>
            <td> @Html.ValidationMessageFor(model => model.Pword_User) </td>
        </tr>

        <tr>
            <td colspan="2">
                <label class="field-validation-error">@Html.DisplayFor(model => model.loginWrong) </label>
            </td>
        </tr>

        <tr>
            <td></td>
            <td>
                <input type="submit" name="" value="conn" />
                <input type="reset" name="" value="reset" />
            </td>
        </tr>
    </table>
}

