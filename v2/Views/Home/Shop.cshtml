@{
    ViewBag.Title = "Shop";
}

<div id="shopHolder" class="container">

    <div id="shopTitle" class=" mainTitle mx-auto">

        <p class="mx-auto">LA BOUTIQUE</p>

    </div>
    
    <div class="shopContainer row">



        <div id="shopFilter" class="col-4">

            <p id="filterTitle">
                Les Filtres
            </p>

            <div class="filterSeparator"></div>

            <div id="filterColor">

                <p class="filterHeader">
                    Trier par couleur:
                </p>

                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="fitlerColorChoice1" value="Red" />
                    <label class="form-check-label" for="fitlerColorTextChoice1">Rouge</label>
                </div>

                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="fitlerColorChoice1" value="Green" />
                    <label class="form-check-label" for="fitlerColorTextChoice1">Vert</label>
                </div>

                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" id="fitlerColorChoice1" value="Blue" />
                    <label class="form-check-label" for="fitlerColorTextChoice1">Bleu</label>
                </div>


                <select class="custom-select custom-select-lg">
                    <option selected>Choisissez une couleur</option>
                    <option value="1">Rouge</option>
                    <option value="2">Vert</option>
                    <option value="3">Bleu</option>
                </select>

            </div>

            <div class="filterSeparator"></div>

            <div id="filterPrice">
                <div class="form-group">
                    <label for="formControlRange">Prix:</label>
                    <input type="range" class="form-control-range" id="formControlRange">
                </div>
            </div>

            <div class="filterSeparator"></div>

            <div id="filterIntra" class="form-check form-check-inline">
                <form>
                    <label for="filterIntraOption">aaaaaaaaaaa:</label>
                    <br />
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="filterIntraOption" id="filterIntraCheckTrue" value="true" />
                        <label class="form-check-label" for="filterIntraTrue">Oui</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="filterIntraOption" id="filterIntraCheckFalse" value="false" />
                        <label class="form-check-label" for="filterIntraFalse">Non</label>
                    </div>
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="radio" name="filterIntraOption" id="filterIntraCheckFalse" value="false" disabled />
                        <label class="form-check-label" for="filterIntraFalse">Maybe</label>
                    </div>
                </form>
            </div>
            <button class="btn btn-default">
                Annuler
            </button>

            <button class="btn btn-primary">
                Valider
            </button>
        </div>

        <div id="shopContent" class="row col-8">

            <div class="col-4 ">
                <div class="card">
                    <img src="~/images/sample.png" />
                    <div class="card-body">
                        <div class="card-title">
                            <h5>
                                Hello
                            </h5>
                        </div>

                        <div class="card-text">
                            <p>world</p>
                        </div>
                        <a class="btn" href="#">no</a>
                    </div>
                </div>
            </div>

            <div class="col-4">
                <div class="card" style="width: 18rem;">
                    <img src="..." class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Card title</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                        <a href="#" class="btn btn-primary">Go somewhere</a>
                    </div>
                </div>
            </div>

            <div class="col-4">
                <div class="card" style="width: 18rem;">
                    <img src="..." class="card-img-top" alt="...">
                    <div class="card-body">
                        <h5 class="card-title">Card title</h5>
                        <p class="card-text">Some quick example text to build on the card title and make up the bulk of the card's content.</p>
                        <a href="#" class="btn btn-primary">Go somewhere</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>