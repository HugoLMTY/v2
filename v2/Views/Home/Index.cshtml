            </div>
        </div>
        <div class="carousel-item" data-bs-interval="2000">
            <img src="~/Ressources/samplePrint_2.jpg" class="d-block w-100">
            <div class="carousel-caption d-none d-md-block carouinfos">
                <h5 class="carouphrase">Bienvenue sur YN2SC</h5>
                <p class="caroutexte">Zebi y'a du boulot la</p>
            </div>
        </div>
        <div class="carousel-item">
            <img src="~/Ressources/samplePrint_3.jpg" class="d-block w-100">
            <div class="carousel-caption d-none d-md-block carouinfos">
                <h5 class="carouphrase">Bienvenue sur FabLabz</h5>
                <p class="caroutexte">Pleins de trucs à voir ici</p>
            </div>
        </div>
    </div>
    <a class="carousel-control-prev" href="#indexCarousel" role="button" data-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="sr-only">Précédent</span>
    </a>
    <a class="carousel-control-next" href="#indexCarousel" role="button" data-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="sr-only">Suivant</span>
    </a>
</div>




<div class="container row mx-auto">

    <div class="container">
        <div id="indexTeamTitle" class="col-6 mainTitle mx-auto">
            <p class="mx-auto">LES EQUIPES</p>
        </div>
    </div>


    <br />

    <div class="col">
        <div class="card h-200">
            <img src="~/Ressources/samplePrint_3.jpg" class="card-img-top" style="height: 150px">
            <div class="card-body">
                <h5 class="card-title">Team Figurine 1</h5>
                <p class="card-text">Superbe figurine wow 10/10</p>
            </div>
            <div class="card-footer">
                <small class="text-muted">mise à jour le 06/01/2021</small>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <img src="~/Ressources/samplePrint_1.jpg" class="card-img-top">
            <div class="card-body">
                <h5 class="card-title">Team Figurine 2</h5>
                <p class="card-text">Figurine insane rien à redire 20/20</p>
            </div>
            <div class="card-footer">
                <small class="text-muted">mise à jour le 06/01/2021</small>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100">
            <img src="~/Ressources/samplePrint_4.jpg" class="card-img-top">
            <div class="card-body">
                <h5 class="card-title">Team le reste</h5>
                <p class="card-text">Amazing 10/10</p>
            </div>
            <div class="card-footer">
                <small class="text-muted">mise à jour le 06/01/2021</small>
            </div>
        </div>
    </div>
</div>







