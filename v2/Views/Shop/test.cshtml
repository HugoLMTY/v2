@using v2.Models




<div class="basket row container mx-auto">

    <div class="zoneBasketInfos col-8">
        <p id="titleBasketContent"></p>

        <div>
            @for (int i = 0; i < 3; i++)
            {
                List<T_Product> products = T_Product.productList;
                foreach (var item in products)
                {
                    <div class="basketLine row">
                        <div class="col-2 basketImg">
                            <img class="productImg" style="width: 100px" src="@item.path_imgproduct" />
                        </div>

                        <div class="col-4 basketProduct">
                            <span class="productName">@item.name_product</span><br />
                            <span class="productInfo">Quantité: 50g</span> <br />
                            <span class="productPrice">@item.id_product€</span>
                        </div>

                        <div class="col-2 basketQty">
                            <input type="number" min="1" max="10" placeholder="-" />
                        </div>

                        <div class="col-2 basketTotalPrice">
                            <p>@item.price_product€</p>
                        </div>

                        <div class="col-2 basketRemoveIcon">
                            <p>T</p>
                        </div>
                    </div>


                }
            }
        </div>
    </div>
    <div class="zoneBasketTotal col-4">
        <div class="basketPayementDetails">
            <p class="basketPriceDetails">
                Produits:
            </p>
            <p class="textPrice">420€</p>

            <p>
                Frais de commande:
            </p>
            <p class="textPrice">0,69€</p>

            <p id="basketTotalPrice">
                Total: <span class="textPrice">420,69€</span>
            </p>
            <button class="btn basketPayementBtn">Accéder au paiement</button>

        </div>
        <form class="row basketReductionCoupon">
            <div class="col-9 inputCouponDiv">
                <input class="form-control" id="basketCoupon" placeholder="Entrer un coupon de réduction" />
            </div>
            <div class="col-3 btnCouponDiv">
                <button id="basketCouponBtn" class="btn">boop</button>
            </div>
        </form>
    </div>
</div>






















