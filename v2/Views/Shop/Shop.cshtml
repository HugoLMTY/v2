@using v2.Models

<div id="shopHolder" class="container">

    <div id="shopTitle" class=" mainTitle mx-auto">

        <p class="mx-auto">LA BOUTIQUE</p>

    </div>

    <div class="shopContainer row">
        <div id="filterHolder" class="col-4">
            @using (Html.BeginForm("FilteringSort", "Shop", FormMethod.Post))
            {

                @Html.DropDownList("test", new[]
           {
               new SelectListItem{Text="Prix ↑", Value="priceUp"},
               new SelectListItem{Text="Prix ↓", Value="priceDown"},
               new SelectListItem{Text="Prix ↑", Value="nameUp"},
               new SelectListItem{Text="Prix ↓", Value="nameDown"}
           })



                <label for="filterSortBy">
                    Trier par:
                </label>

                <input type="submit" name="name" class="btn btn-context" value="Trier" />
                <input type="reset" name="name" class="btn" value="Annuler" />
            }

        </div>
        <div id="shopContent" class="row col-8">

            @foreach (var item in T_Product.productList     )
            {
                <div class="col-4">
                    <div class="cardWrap">
                        <div class="card">
                            <img height="120" src="@item.path_imgproduct" />
                            <div class="card-body">
                                <div class="card-title">
                                    <h2>
                                        @item.name_product
                                    </h2>
                                </div>

                                <div class="card-text">
                                    <p style="font-weight:bold">@item.desc_product</p>
                                    <p>
                                        @item.lenght_product x @item.width_product x @item.height_product (cm)<br />
                                        Quantité: @item.qty_product.
                                    </p>
                                    <p style="font-weight:bold">@item.price_product€</p>
                                </div>
                                @Html.ActionLink("Plus d'infos", "getActiveProduct", "Shop", @item.id_product, new { type = "button", @class = "btn btn-context", data_toggle = "modal", data_target = "#modalProduct" })
                            </div>
                        </div>
                    </div>
                </div>
                }
        </div>
    </div>
</div>





