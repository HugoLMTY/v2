@using v2.Job
@model v2.Models.T_User

@using (Html.BeginForm("AddUser", "User", FormMethod.Post))
{

<div class="jumbotron container">
    <h1 class="display-4">Créez votre compte</h1>
    <p>page de création de compte balh blah bnlah nlah blah labh</p>
    <hr class="my-4" />
    <p class="lead"></p>

    @if (Session["mailState"] != null)
    {
        <div class="alert alert-danger" role="alert">
            <strong>
                @Session["mailState"]
            </strong>
            <button type="button" class="close" data-dismiss="alert" aria-label="Fermer">
                <span aria-hidden="true">&times;</span>
            </button>
        </div>

        Session.Remove("mailState");
    }

    <div class="row">
        <div class="form-group col-3">
            @Html.LabelFor(model => model.firstname_user, new { @for = "createFirstName" })
            @Html.TextBoxFor(model => model.firstname_user, new { @class = "form-control", @id = "createFirstName", placeholder = "Prénom", autocomplete = "off" })
            @Html.ValidationMessageFor(model => model.firstname_user)
        </div>

        <div class="form-group col-3">
            @Html.LabelFor(model => model.name_user, new { @for = "createFirstName"})
            @Html.TextBoxFor(model => model.name_user, new { @class = "form-control", placeholder = "Nom", autocomplete = "off" })
            @Html.ValidationMessageFor(model => model.name_user)
        </div>

        <div class="form-group col-6">
            @Html.LabelFor(model => model.mail_user)
            @Html.TextBoxFor(model => model.mail_user, new { @class = "form-control", placeholder = "Mail", autocomplete = "off" })
            @Html.ValidationMessageFor(model => model.mail_user)
        </div>

        <div class="form-group col-1">
            @Html.LabelFor(model => model.age_user)
            @Html.TextBoxFor(model => model.age_user, new { @class = "form-control", placeholder = "Âge", autocomplete = "off" })
        </div>

        <div class="form-group col-4">
            @Html.LabelFor(model => model.tel_user)
            @Html.TextBoxFor(model => model.tel_user, new { @class = "form-control", placeholder = "Téléphone", autocomplete = "off" })
        </div>

        <div class="form-group col-5">
            @Html.LabelFor(model => model.adress_user)
            @Html.TextBoxFor(model => model.adress_user, new { @class = "form-control", placeholder = "Téléphone", autocomplete = "off" })
            @Html.ValidationMessageFor(model => model.adress_user)
        </div>

        <div class="form-group col-5">
            @Html.LabelFor(model => model.pword_user)
            @Html.PasswordFor(model => model.pword_user, new { @class = "form-control", placeholder = "Mot de passe", autocomplete = "off" })
            @Html.ValidationMessageFor(model => model.pword_user)
        </div>
    </div>

    <input type="submit" clas accepts="btn btn-primary" value="Créer son compte" />
    @Html.ActionLink("Annuler", "Index", "Home", new { @class = "btn" })
</div>
}







