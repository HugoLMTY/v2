
<table id="tableBasketList">
    <thead id="basketListHeader">
        <tr>
            <td>
                Référence
            </td>

            <td>
                Nombre d'articles
            </td>

            <td>
                Date de commande
            </td>

            <td>
                Prix total
            </td>

            <td>
                Status de la commande
            </td>

            <td>
            </td>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model.basket)
        {
            <tr class="style1">
                <td id="tableBasketId">
                    <string>
                        @item.id_basket
                    </string>
                </td>

                <td id="tableBasketQty">
                    <string>
                        @item.qty_basket
                    </string>
                </td>

                <td id="tableBasketDate" style="text-align:center">
                    <string>
                        @item.date_basket.ToShortDateString()
                    </string>
                </td>

                <td id="tableBasketPrice">
                    <string>
                        <strong>
                            @item.price_basket€
                        </strong>
                    </string>
                </td>

                <td id="tableBasketStatus" style="font-style:italic">
                    <string>
                        @item.status_basket
                    </string>
                </td>

                <td id="tableBasketMore">
                    @Html.ActionLink("Détails de la commande", "BasketDetails", "User",
                   new {obj = item.id_basket})
                   @*new AjaxOptions {
                       InsertionMode = InsertionMode.Replace,
                       UpdateTargetId = "tableBasketList"
                   })*@
                </td>
            </tr>
        }
    </tbody>
</table>
